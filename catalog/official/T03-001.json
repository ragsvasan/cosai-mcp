{
  "schema_version": "1.1",
  "id": "T03-001",
  "category": "T3",
  "severity": "critical",
  "cosai_ref": "T3",
  "owasp_ref": "MCP-Top10-A03",
  "cwe": [
    "CWE-77",
    "CWE-78"
  ],
  "confidence": "high",
  "probes": [
    {
      "id": "T03-001-p1",
      "transport": "http",
      "method": "tools/call",
      "payload": {
        "name": "{{tool_name}}",
        "arguments": {
          "cmd": "; cat /etc/passwd",
          "input": "; cat /etc/passwd"
        }
      },
      "assertions": [
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "root:"
        },
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "/bin/bash"
        }
      ],
      "corroboration": [
        {
          "target": "response.body",
          "operator": "contains",
          "value": "root:",
          "description": "Positive command-output evidence: the injected `cat /etc/passwd` actually executed and the canonical /etc/passwd record marker is present — not merely an incidental denylist substring."
        },
        {
          "target": "response.body",
          "operator": "contains",
          "value": ":/",
          "description": "Second independent /etc/passwd structural marker (home-dir path field), so a lone 'root:' token is insufficient to report a finding."
        }
      ]
    },
    {
      "id": "T03-001-p2",
      "transport": "http",
      "method": "tools/call",
      "payload": {
        "name": "{{tool_name}}",
        "arguments": {
          "cmd": "$(id)",
          "input": "`id`"
        }
      },
      "assertions": [
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "uid="
        },
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "gid="
        }
      ],
      "corroboration": [
        {
          "target": "response.body",
          "operator": "contains",
          "value": "uid=",
          "description": "Positive command-output evidence: the injected `id` executed and emitted a uid= field."
        },
        {
          "target": "response.body",
          "operator": "contains",
          "value": "gid=",
          "description": "Second independent `id` output field, so a lone 'uid=' token is insufficient to report a finding."
        }
      ]
    },
    {
      "id": "T03-001-p3",
      "transport": "http",
      "method": "tools/call",
      "payload": {
        "name": "{{tool_name}}",
        "arguments": {
          "path": "/etc/passwd",
          "file": "/etc/shadow"
        }
      },
      "assertions": [
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "root:"
        },
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "daemon:"
        }
      ],
      "corroboration": [
        {
          "target": "response.body",
          "operator": "contains",
          "value": "root:",
          "description": "Positive evidence the path-traversal read returned /etc/passwd content."
        },
        {
          "target": "response.body",
          "operator": "contains",
          "value": "daemon:",
          "description": "Second independent /etc/passwd account marker, so a lone 'root:' token is insufficient to report a finding."
        }
      ]
    }
  ],
  "remediation": "Validate and sanitise all tool arguments against a strict JSON Schema. Never pass user-controlled values to shell commands or file paths without allow-listing.",
  "references": [
    "https://cosai.org/T3",
    "https://cwe.mitre.org/data/definitions/78.html"
  ]
}
