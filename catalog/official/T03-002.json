{
  "schema_version": "1.1",
  "id": "T03-002",
  "category": "T3",
  "severity": "high",
  "cosai_ref": "T3",
  "owasp_ref": "MCP-Top10-A03",
  "cwe": [
    "CWE-22"
  ],
  "confidence": "high",
  "probes": [
    {
      "id": "T03-002-p1",
      "transport": "http",
      "method": "tools/call",
      "payload": {
        "name": "{{tool_name}}",
        "arguments": {
          "path": "../../etc/passwd",
          "filename": "../../../etc/hosts"
        }
      },
      "assertions": [
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "root:"
        },
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "127.0.0.1"
        }
      ],
      "corroboration": [
        {
          "target": "response.body",
          "operator": "contains",
          "value": "root:",
          "description": "Positive evidence the traversal read returned /etc/passwd content, not merely an incidental denylist substring."
        },
        {
          "target": "response.body",
          "operator": "contains",
          "value": ":/",
          "description": "Second independent /etc/passwd structural marker, so a lone token is insufficient to report a finding."
        }
      ]
    },
    {
      "id": "T03-002-p2",
      "transport": "http",
      "method": "tools/call",
      "payload": {
        "name": "{{tool_name}}",
        "arguments": {
          "path": "%2e%2e%2f%2e%2e%2fetc%2fpasswd"
        }
      },
      "assertions": [
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "root:"
        }
      ],
      "corroboration": [
        {
          "target": "response.body",
          "operator": "contains",
          "value": "root:",
          "description": "Positive evidence the URL-encoded traversal read returned /etc/passwd content."
        },
        {
          "target": "response.body",
          "operator": "contains",
          "value": ":/",
          "description": "Second independent /etc/passwd structural marker, so a lone 'root:' token is insufficient to report a finding."
        }
      ]
    }
  ],
  "remediation": "Canonicalise paths before use and verify the resolved path is within the allowed directory using Path.is_relative_to().",
  "references": [
    "https://cosai.org/T3",
    "https://cwe.mitre.org/data/definitions/22.html"
  ]
}
