{
  "schema_version": "1.0",
  "id": "T08-004",
  "category": "T8",
  "severity": "critical",
  "cosai_ref": "T8",
  "owasp_ref": "MCP-Top10-A08",
  "cwe": [
    "CWE-918"
  ],
  "probes": [
    {
      "id": "T08-004-p1",
      "transport": "http",
      "method": "tools/call",
      "payload": {
        "name": "{{tool_name}}",
        "arguments": {
          "url": "http://metadata.google.internal/computeMetadata/v1/instance/"
        }
      },
      "assertions": [
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "computeMetadata"
        },
        {
          "target": "response.body",
          "operator": "not_contains",
          "value": "numericProjectId"
        }
      ]
    }
  ],
  "remediation": "Block requests to GCP metadata endpoint (metadata.google.internal / 169.254.169.254) at the HTTP client level. Validate URL arguments against an allowlist that rejects link-local and well-known metadata hostnames before any network call is made.",
  "references": [
    "https://cosai.org/T8",
    "https://cwe.mitre.org/data/definitions/918.html",
    "https://cloud.google.com/compute/docs/metadata/overview"
  ]
}
