  "cwe": [
    "CWE-918"
  ],
  "probes": [
    {
      "id": "T08-009-p1",
      "transport": "http",
      "method": "tools/call",
      "payload": {
        "name": "{{tool_name}}",
        "arguments": {
          "url": "http://[fd00::1]/"
        }
      },
      "assertions": [
        {
          "target": "response.error",
          "operator": "eq",
          "value": true
        }
      ],
      "protocol_error_is_expected": true
    },
    {
      "id": "T08-009-p2",
      "transport": "http",
      "method": "tools/call",
      "payload": {
        "name": "{{tool_name}}",
        "arguments": {
          "url": "http://[fe80::1]/"
        }
      },
      "assertions": [
        {
          "target": "response.error",
          "operator": "eq",
          "value": true
        }
      ],
      "protocol_error_is_expected": true
    }
  ],
  "remediation": "Block IPv6 ULA (fc00::/7) and link-local (fe80::/10) address ranges at the HTTP client level. A server that fetches these addresses instead of rejecting them exposes internal IPv6 network services. Ensure the URL allowlist covers both IPv4 and IPv6 private/link-local ranges.",
  "references": [
    "https://cosai.org/T8",
